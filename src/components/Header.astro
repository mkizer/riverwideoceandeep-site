---
import { SITE_TITLE } from '../consts';
import HeaderLink from './HeaderLink.astro';
---

	<nav>
		<h2>
			<a href="/"><img src="/MichaelSchauer_WhereTheRiverMeetsTheOcean.png" alt="" class="header-logo" /> <i>{SITE_TITLE}</i></a>
		</h2>
		<div class="internal-links">
			<a href="/rss.xml" class="rss-link" aria-label="RSS Feed" title="RSS Feed">
				<svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 11a9 9 0 0 1 9 9"></path><path d="M4 4a16 16 0 0 1 16 16"></path><circle cx="5" cy="19" r="1"></circle></svg>
			</a>
			<HeaderLink href="/tags/">Tags</HeaderLink>
			<HeaderLink href="/about/">About</HeaderLink>
		</div>
	</nav>
</header>
<style>
	header {
		margin: 0;
		padding: 0 1em;
		background: white;
		box-shadow: 0 2px 8px rgba(var(--black), 5%);
	}
	h2 {
		margin: 0;
		font-size: 1em;
	}

	h2 a,
	h2 a.active {
		text-decoration: none;
		display: flex;
		align-items: center;
	}
	nav {
		display: flex;
		align-items: center;
		justify-content: space-between;
	}
	nav a {
		padding: 1em 0.5em;
		color: var(--black);
		border-bottom: 4px solid transparent;
		text-decoration: none;
	}
	nav a.active {
		text-decoration: none;
		border-bottom-color: var(--accent);
	}
	.header-logo {
		height: 3em;
		width: auto;
		margin-right: 0.5em;
	}
	.internal-links {
		margin-left: auto;
		display: flex;
		align-items: center;
	}
	.rss-link {
		display: flex;
		align-items: center;
		color: var(--black);
		padding: 1em 0.5em;
	}
	.rss-link:hover {
		color: var(--accent);
	}
</style>
